{
  "name": "n8n-nodes-blackbee",
  "version": "0.2.2",
  "description": "n8n community node for the Blackbee Accounts-Payable API.",
  "author": {
    "name": "Blackbee",
    "email": "platform.services@cratoflow.com",
    "url": "https://blackbeeai.com"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "blackbee",
    "accounts-payable",
    "vendor"
  ],
  "license": "MIT",
  "homepage": "https://github.com/blackbeeofficial/n8n-node#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blackbeeofficial/n8n-node.git"
  },
  "bugs": {
    "url": "https://github.com/blackbeeofficial/n8n-node/issues"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "dist/nodes/Blackbee/Blackbee.node.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials --ext .ts",
    "lint:fix": "eslint nodes credentials --ext .ts --fix"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/BlackbeeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Blackbee/Blackbee.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.56.0",
    "typescript": "~5.1.6"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
